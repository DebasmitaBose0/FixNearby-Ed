# =============================================================================
# FixNearby – Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in your own values.
#
# Required variables are marked [REQUIRED]. The server will refuse to start
# without them.  Optional variables are marked [OPTIONAL]; the server will
# run with degraded functionality if they are missing.
# =============================================================================

# --- Server ------------------------------------------------------------------
# [REQUIRED] Port the Express server listens on
PORT=5000

# [REQUIRED] Secret used to sign JSON Web Tokens
JWT_SECRET=your_jwt_secret_here

# --- Database ----------------------------------------------------------------
# [OPTIONAL] MongoDB connection string.
# If omitted the server runs in in-memory fallback mode (useful for local dev).
MONGODB_URI=mongodb://localhost:27017/FixNearby

# --- Frontend ----------------------------------------------------------------
# [OPTIONAL] Base URL of the Vite dev server (used in password-reset emails)
CLIENT_URL=http://localhost:5173

# [OPTIONAL] API base URL consumed by the React client
VITE_API_URL=http://localhost:5000/api

# --- Email (Brevo) -----------------------------------------------------------
# [OPTIONAL] Required only if you want password-reset emails to work.
BREVO_API_KEY=brevo_api_key_here
BREVO_SENDER_NAME=sender_side_name_here
BREVO_SENDER_EMAIL=sender_side_email_here
