# =============================================================================
# FixNearby Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/FixNearby

# --- Authentication ---
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=30d

# --- Redis (for caching and BullMQ job queues) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Email (Brevo/Sendinblue) ---
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_NAME=FixNearby
BREVO_SENDER_EMAIL=noreply@fixnearby.com

# --- Client URLs (CORS allowlist) ---
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000/api

# --- External Error Reporting (optional) ---
# ERROR_WEBHOOK_URL=https://hooks.example.com/errors

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
